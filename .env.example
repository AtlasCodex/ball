# 复制为 .env 后填写真实值

# 元宝（YuanBao-Free-API 等 OpenAI 兼容服务）
YUANBAO_API_KEY=your_api_key_here
YUANBAO_BASE_URL=http://localhost:8000/v1
YUANBAO_MODE=free_api
YUANBAO_TO=your_yuanbao_account

# 若使用腾讯云混元官方 API
# TENCENT_SECRET_ID=xxx
# TENCENT_SECRET_KEY=xxx

# 可选：覆盖数据库地址
# DATABASE_URL=sqlite:///data/ball.db

# 邮箱推送 SMTP 授权码（163 邮箱，非登录密码，是“客户端授权码”）
EMAIL_AUTH_CODE=your_163_auth_code_here

